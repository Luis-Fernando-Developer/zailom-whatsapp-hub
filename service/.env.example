# ============================================================================
# ZAILOM WA-SERVICE — Environment variables
# ============================================================================
# Copy to `.env` (local) or set via Portainer stack env in production.

# --- Runtime ----------------------------------------------------------------
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# --- Supabase (external, dedicated) -----------------------------------------
# Where to get each:
#   Dashboard > Project Settings > Data API      -> SUPABASE_URL
#   Dashboard > Project Settings > API Keys      -> service_role (secret)
#   Dashboard > Project Settings > Database      -> Connection string
#     Use the SESSION pooler string (port 5432), not the transaction pooler.
SUPABASE_URL=https://bcouunitysjtsjvwulnh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
DATABASE_URL=postgresql://postgres.bcouunitysjtsjvwulnh:REPLACE_ME@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Evolution API ----------------------------------------------------------
EVOLUTION_BASE_URL=https://api-evo.zailom.com
EVOLUTION_GLOBAL_API_KEY=REPLACE_ME

# --- Public base URL of THIS service (used to build Evolution webhook URLs) -
PUBLIC_BASE_URL=https://wa.zailom.com

# --- Admin API (create tenants, mint api keys) ------------------------------
# Long random string. Generate with:  openssl rand -hex 32
ADMIN_TOKEN=REPLACE_ME

# --- Webhook fan-out --------------------------------------------------------
# HMAC secret used to sign every outbound webhook the service delivers to
# tenants (Booking/Flow). Tenants verify with the same secret.
# Generate with:  openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=REPLACE_ME

# Optional shared secret Evolution sends on every inbound webhook. If set,
# incoming requests must include it in header X-Evolution-Token.
EVOLUTION_INBOUND_TOKEN=

# --- CORS -------------------------------------------------------------------
CORS_ORIGINS=https://booking.zailom.com,https://flow.zailom.com,https://app.zailom.com

# --- Rate limit -------------------------------------------------------------
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000